<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f0f2f5; -fx-padding: 20;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.SellerManagementController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 0 0 20 0;">
            <Label text="Kênh Quản Lý Bán Hàng" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnAddItem" text="+ Thêm Sản Phẩm Mới" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 14px;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20">
            <HBox spacing="20">
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 5, 0, 0, 2);">
                    <Label text="Tổng Doanh Thu (Ước tính)" style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;"/>
                    <Label text="125,000,000 VNĐ" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                </VBox>
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 5, 0, 0, 2);">
                    <Label text="Sản Phẩm Đang Chờ Đấu Giá" style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;"/>
                    <Label text="05" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>
                </VBox>
            </HBox>

            <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 5, 0, 0, 2);">
                <Label text="Danh Sách Sản Phẩm Của Bạn" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 0 0 15 0;"/>
                <TableView fx:id="productsTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 14px;">
                    <columns>
                        <TableColumn text="Mã SP" prefWidth="80" style="-fx-alignment: CENTER;"/>
                        <TableColumn text="Tên Sản Phẩm" prefWidth="350" />
                        <TableColumn text="Giá Hiện Tại" prefWidth="180" style="-fx-alignment: CENTER_RIGHT;"/>
                        <TableColumn text="Trạng Thái" prefWidth="150" style="-fx-alignment: CENTER;"/>
                        <TableColumn text="Hành Động" prefWidth="150" style="-fx-alignment: CENTER;"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>