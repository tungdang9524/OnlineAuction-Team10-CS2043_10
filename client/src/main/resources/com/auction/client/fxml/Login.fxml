<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<VBox alignment="CENTER" prefHeight="452.0" prefWidth="351.0" spacing="20.0" style="-fx-spacing: 15; -fx-padding: 40; -fx-background-color: white; -fx-background-radius: 20px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 40, 0, 0, 10); -fx-border-radius: 20px;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.LoginController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

                      <Label fx:id="errorLabel" managed="false" textFill="RED" visible="false" />
   <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
      <image>
         <Image url="@images/Gemini_Generated_Image_kb724dkb724dkb72.png" />
      </image>
   </ImageView>

                      <TextField fx:id="usernameField" prefHeight="45.0" prefWidth="250.0" promptText="Tên đăng nhập" style="-fx-background-color: #f5f5f5; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 10 0 10;" />
    <PasswordField fx:id="passwordField" prefHeight="45.0" prefWidth="250.0" promptText="Mật khẩu" style="-fx-background-color: #f5f5f5; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 10 0 10;" />
   <HBox alignment="CENTER" prefHeight="7.0" prefWidth="237.0">
      <children>
         <Label prefHeight="17.0" prefWidth="126.0" text="Bạn chưa có tài khoản ?" />
          <Button fx:id="registerBtn" mnemonicParsing="false" onAction="#handleRegister" prefHeight="25.0" prefWidth="99.0" style="-fx-background-color: transparent; -fx-text-fill: #1877F2; -fx-font-weight: bold;" text="Đăng Ký Ngay">
            <cursor>
               <Cursor fx:constant="HAND" />
            </cursor>
         </Button>
      </children>
   </HBox>

                      <Button fx:id="loginBtn" mnemonicParsing="false" onAction="#handleLogin" prefHeight="40.0" prefWidth="250.0" style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-font-weight: bold; -fx-font-size: 14px;" text="Đăng Nhập">
