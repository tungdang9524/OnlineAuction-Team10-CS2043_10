<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="8.0" style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5; -fx-background-color: white;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>

    <ImageView fx:id="itemImageView" fitHeight="120.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true" />

    <Label fx:id="itemNameLabel" text="iPhone 15 Pro Max 256GB" wrapText="true">
        <font>
            <Font name="System Bold" size="14.0" />
        </font>
    </Label>

    <Label fx:id="currentPriceLabel" text="Giá: $1,200" textFill="#28a745">
        <font>
            <Font name="System Bold" size="16.0" />
        </font>
    </Label>

    <Label fx:id="timeLeftLabel" text="Còn lại: 02:15:30" textFill="#dc3545" />

    <Button fx:id="viewDetailBtn" mnemonicParsing="false" text="Xem Chi Tiết / Đấu Giá" prefWidth="150.0"/>
</VBox>